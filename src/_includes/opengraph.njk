{% if canonicalUrl %}
    <link rel="canonical" href="{{ canonicalUrl }}"/>
{% endif %}
<meta property="og:title" content="{{ ogTitle or title or 'CLIR Publications' }}"/>
<meta property="og:description" content="{{ ogDescription or description or 'Research, resources, and media from CLIR Publications.' }}"/>
<meta property="og:type" content="{{ ogType or 'website' }}"/>
{% if ogUrl %}
    <meta property="og:url" content="{{ ogUrl }}"/>
{% endif %}
<meta name="twitter:card" content="{{ twitterCard or 'summary' }}"/>
<meta name="twitter:title" content="{{ twitterTitle or ogTitle or title or 'CLIR Publications' }}"/>
<meta name="twitter:description" content="{{ twitterDescription or ogDescription or description or 'Research, resources, and media from CLIR Publications.' }}"/>
{% if reportJsonLd %}
    <script type="application/ld+json">
        {{ reportJsonLd | json | safe }}
    </script>
{% endif %}